<Window
    x:Class="RoboCopyGUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RoboCopyGUI"
    xmlns:vm="using:RoboCopyGUI.ViewModels"
    xmlns:m="using:RoboCopyGUI.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="MainGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Padding="16,32,8,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                <FontIcon Glyph="&#xE8F1;" FontSize="20" />
                <TextBlock Text="RoboCopy GUI" Style="{StaticResource SubtitleTextBlockStyle}" VerticalAlignment="Center" />
            </StackPanel>

            <CommandBar Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                        DefaultLabelPosition="Right" Background="Transparent" IsOpen="False"
                        Margin="0,0,80,0">
                <AppBarButton Icon="Add" Label="添加任务" Click="AddTask_Click" />
                <AppBarButton Icon="Play" Label="开始队列" Click="StartQueue_Click" />
                <AppBarButton Icon="Stop" Label="取消" Click="CancelQueue_Click" />
                <AppBarSeparator />
                <AppBarButton Icon="Save" Label="保存队列" Click="SaveQueue_Click" />
                <AppBarButton Icon="Setting" Label="设置" Click="Settings_Click" />
            </CommandBar>
        </Grid>

        <Grid Grid.Row="1" Padding="16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" MinWidth="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" CornerRadius="8"
                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                  BorderThickness="1" Padding="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="任务队列" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,12" />

                <Grid Grid.Row="1" Margin="0,0,0,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <AutoSuggestBox Grid.Row="0" Grid.Column="0" PlaceholderText="源路径..."
                                    x:Name="SourceBox" QueryIcon="Folder" Margin="0,0,4,8" />
                    <Button Grid.Row="0" Grid.Column="1" Click="BrowseSource_Click"
                            ToolTipService.ToolTip="浏览" Margin="0,0,0,8"
                            Style="{StaticResource SubtleButtonStyle}">
                        <FontIcon Glyph="&#xE8B7;" FontSize="14" />
                    </Button>

                    <AutoSuggestBox Grid.Row="1" Grid.Column="0" PlaceholderText="目标路径..."
                                    x:Name="DestBox" QueryIcon="SyncFolder" Margin="0,0,4,0" />
                    <Button Grid.Row="1" Grid.Column="1" Click="BrowseDest_Click"
                            ToolTipService.ToolTip="浏览"
                            Style="{StaticResource SubtleButtonStyle}">
                        <FontIcon Glyph="&#xE8B7;" FontSize="14" />
                    </Button>
                </Grid>

                <ListView Grid.Row="2" Padding="0" SelectionMode="Single" IsItemClickEnabled="True"
                          ItemsSource="{Binding Tasks}" SelectedItem="{Binding SelectedTask, Mode=TwoWay}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:CopyTaskViewModel">
                            <Grid Padding="8,6" CornerRadius="6" Margin="0,0,0,4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="4"
                                        Width="4" CornerRadius="2" Margin="0,0,8,0"
                                        Background="Gray" />

                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="{x:Bind Source}"
                                           Style="{StaticResource BodyStrongTextBlockStyle}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Row="1" Grid.Column="1"
                                           Text="{x:Bind Destination}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis" FontSize="12" />
                                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                    <TextBlock Text="{x:Bind Status}" FontSize="11" />
                                    <TextBlock Text="{x:Bind PresetName}" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                </StackPanel>
                                <Grid Grid.Row="3" Grid.Column="1" Margin="0,6,0,0" Height="20" CornerRadius="10"
                                      Background="#33FFFFFF">
                                    <ProgressBar Value="{x:Bind ProgressPercent}" Maximum="100" Height="20"
                                                 CornerRadius="10"
                                                 Foreground="{ThemeResource SystemAccentColor}"
                                                 Background="Transparent"
                                                 BorderThickness="0" />
                                    <Border CornerRadius="10">
                                        <TextBlock FontSize="11" FontWeight="Bold"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Run Text="{x:Bind ProgressPercent, Mode=OneWay}" /><Run Text="%" />
                                        </TextBlock>
                                    </Border>
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>

                <StackPanel Grid.Row="3" Spacing="4" Margin="0,8,0,0">
                    <Grid Height="20" CornerRadius="10" Margin="0,0,0,4" Background="#33FFFFFF">
                        <ProgressBar Value="{Binding OverallProgress}" Maximum="100" Height="20"
                                     CornerRadius="10"
                                     Foreground="{ThemeResource SystemAccentColor}"
                                     Background="Transparent"
                                     BorderThickness="0" />
                        <Border CornerRadius="10">
                            <TextBlock FontSize="11" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Text="{Binding OverallProgressText}" />
                        </Border>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Button Content="上移" Click="MoveUp_Click" Style="{StaticResource SubtleButtonStyle}" />
                        <Button Content="下移" Click="MoveDown_Click" Style="{StaticResource SubtleButtonStyle}" />
                        <Button Content="复制" Click="Duplicate_Click" Style="{StaticResource SubtleButtonStyle}" />
                        <Button Content="删除" Click="Remove_Click" Style="{StaticResource SubtleButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Grid>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" CornerRadius="8"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                      BorderThickness="1" Padding="16" Margin="0,0,0,8">
                    <TextBlock Text="配置" Style="{StaticResource BodyStrongTextBlockStyle}" />
                </Grid>

                <Grid Grid.Row="1" CornerRadius="8"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                      BorderThickness="1" Padding="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="运行日志" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,12" />

                    <ListView Grid.Row="1" Padding="0" IsItemClickEnabled="False" SelectionMode="None"
                              ItemsSource="{Binding LogEntries}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="m:LogEntry">
                                <StackPanel Orientation="Horizontal" Spacing="8" Padding="2">
                                    <TextBlock Text="{x:Bind Timestamp.Hour}" FontSize="11" FontFamily="Consolas"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" MinWidth="60" />
                                    <TextBlock Text="{x:Bind Message}" FontSize="12" FontFamily="Consolas"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="4,2" />
                                <Setter Property="MinHeight" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </Grid>
            </Grid>
        </Grid>

        <Grid Grid.Row="2" Padding="16,4" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="{Binding StatusText}" FontSize="12"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
            <TextBlock Grid.Column="1" FontSize="11"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center">
                <Run Text="任务:" /><Run Text="{Binding Tasks.Count}" />
            </TextBlock>
            <TextBlock Grid.Column="2" FontSize="11"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center">
                <Run Text="日志:" /><Run Text="{Binding LogEntries.Count}" />
            </TextBlock>
        </Grid>
    </Grid>
</Window>
