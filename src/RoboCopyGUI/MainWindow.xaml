<Window
    x:Class="RoboCopyGUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RoboCopyGUI"
    xmlns:vm="using:RoboCopyGUI.ViewModels"
    xmlns:m="using:RoboCopyGUI.Models"
    xmlns:ctrl="using:RoboCopyGUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="MainGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="48" Padding="16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                <FontIcon Glyph="&#xE8F1;" FontSize="20" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                <TextBlock Text="RoboCopy GUI" Style="{StaticResource SubtitleTextBlockStyle}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <CommandBar Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center"
                        DefaultLabelPosition="Right" Background="Transparent"
                        IsOpen="False">
                <AppBarButton Icon="Add" Label="Add Task"
                              Command="{Binding AddTaskCommand}" />
                <AppBarButton Icon="Play" Label="Start Queue"
                              Command="{Binding StartQueueCommand}" />
                <AppBarButton Icon="Stop" Label="Cancel"
                              Command="{Binding CancelQueueCommand}" />
                <AppBarSeparator />
                <AppBarButton Icon="Save" Label="Save Queue"
                              Command="{Binding SaveQueueCommand}" />
                <AppBarButton Icon="OpenFile" Label="Load Queue"
                              Click="LoadQueue_Click" />
                <AppBarSeparator />
                <AppBarButton Icon="Export" Label="Export .bat"
                              Click="ExportBat_Click" />
                <AppBarButton Icon="Export" Label="Export .ps1"
                              Click="ExportPs1_Click" />
                <AppBarSeparator />
                <AppBarButton Icon="Clear" Label="Clear Done"
                              Command="{Binding ClearCompletedCommand}" />
                <AppBarButton Icon="Setting" Label="Settings"
                              Click="Settings_Click" />
            </CommandBar>
        </Grid>

        <Grid Grid.Row="1" Padding="16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" MinWidth="280" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" CornerRadius="8"
                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                  BorderThickness="1" Padding="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Task Queue" Style="{StaticResource BodyStrongTextBlockStyle}"
                           Margin="0,0,0,12" />

                <Grid Grid.Row="1" Margin="0,0,0,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <AutoSuggestBox Grid.Row="0" Grid.ColumnSpan="2"
                                    PlaceholderText="Source path..."
                                    Text="{Binding SourcePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    QueryIcon="Folder"
                                    Margin="0,0,0,8" />

                    <AutoSuggestBox Grid.Row="1" Grid.Column="0"
                                    PlaceholderText="Destination path..."
                                    Text="{Binding DestinationPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    QueryIcon="SyncFolder" />
                </Grid>

                <ListView Grid.Row="2" ItemsSource="{Binding Tasks}"
                          SelectedItem="{Binding SelectedTask, Mode=TwoWay}"
                          SelectionMode="Single" Padding="0"
                          CanReorderItems="True" AllowDrop="True"
                          IsItemClickEnabled="True">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:CopyTaskViewModel">
                            <Grid Padding="8,6" CornerRadius="6"
                                  Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                  Margin="0,0,0,4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="4"
                                        Width="4" CornerRadius="2" Margin="0,0,8,0"
                                        Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}" />

                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="{Binding Source}"
                                           Style="{StaticResource BodyStrongTextBlockStyle}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Row="1" Grid.Column="1"
                                           Text="{Binding Destination}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           FontSize="12" />
                                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                    <TextBlock Text="{Binding Status, Converter={StaticResource StatusToStringConverter}}"
                                               FontSize="11"
                                               Foreground="{Binding Status, Converter={StaticResource StatusToColorConverter}}" />
                                    <TextBlock Text="{Binding PresetName}"
                                               FontSize="11"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                </StackPanel>
                                <ProgressBar Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"
                                             Value="{Binding ProgressPercent}" Maximum="100"
                                             Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}"
                                             Margin="0,4,0,0" Height="4" />

                                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Spacing="4">
                                    <Button Style="{StaticResource SubtleButtonStyle}"
                                            Visibility="{Binding IsPending, Converter={StaticResource BoolToVisibilityConverter}}"
                                            Command="{Binding DataContext.DryRunCommand, ElementName=MainGrid}"
                                            CommandParameter="{Binding}"
                                            ToolTipService.ToolTip="Dry Run">
                                        <FontIcon Glyph="&#xE9CE;" FontSize="14" />
                                    </Button>
                                    <Button Style="{StaticResource SubtleButtonStyle}"
                                            Visibility="{Binding CanCancel, Converter={StaticResource BoolToVisibilityConverter}}"
                                            Command="{Binding DataContext.CancelSingleCommand, ElementName=MainGrid}"
                                            CommandParameter="{Binding}"
                                            ToolTipService.ToolTip="Cancel">
                                        <FontIcon Glyph="&#xE711;" FontSize="14" Foreground="OrangeRed" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>

                <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                    <Button Content="Move Up" Command="{Binding MoveUpCommand}"
                            CommandParameter="{Binding SelectedTask}" Style="{StaticResource SubtleButtonStyle}">
                        <Button.Icon><FontIcon Glyph="&#xE70E;" /></Button.Icon>
                    </Button>
                    <Button Content="Move Down" Command="{Binding MoveDownCommand}"
                            CommandParameter="{Binding SelectedTask}" Style="{StaticResource SubtleButtonStyle}">
                        <Button.Icon><FontIcon Glyph="&#xE70D;" /></Button.Icon>
                    </Button>
                    <Button Content="Duplicate" Command="{Binding DuplicateCommand}"
                            CommandParameter="{Binding SelectedTask}" Style="{StaticResource SubtleButtonStyle}">
                        <Button.Icon><FontIcon Glyph="&#xE8C8;" /></Button.Icon>
                    </Button>
                    <Button Content="Remove" Command="{Binding RemoveCommand}"
                            CommandParameter="{Binding SelectedTask}" Style="{StaticResource SubtleButtonStyle}">
                        <Button.Icon><FontIcon Glyph="&#xE74D;" Foreground="OrangeRed" /></Button.Icon>
                    </Button>
                </StackPanel>
            </Grid>

            <Border Grid.Column="1" Width="1" HorizontalAlignment="Center"
                    Background="{ThemeResource CardStrokeColorDefaultBrush}" />

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" CornerRadius="8"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                      BorderThickness="1" Padding="16"
                      Margin="0,0,0,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Configuration" Style="{StaticResource BodyStrongTextBlockStyle}"
                               Margin="0,0,0,12" />

                    <Grid Grid.Row="1" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="6">
                            <TextBlock Text="Source" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Text="{Binding SelectedTask.Source}" TextTrimming="CharacterEllipsis"
                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                        </StackPanel>

                        <FontIcon Grid.Column="1" Glyph="&#xE71A;" VerticalAlignment="Center"
                                  Margin="16,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                        <StackPanel Grid.Column="2" Spacing="6">
                            <TextBlock Text="Destination" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Text="{Binding SelectedTask.Destination}" TextTrimming="CharacterEllipsis"
                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                            <TextBlock Text="Status" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Text="{Binding CurrentTaskStatus, Converter={StaticResource StatusToStringConverter}}"
                                       Foreground="{Binding CurrentTaskStatus, Converter={StaticResource StatusToColorConverter}}"
                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                            <TextBlock Text="Overall Progress" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Text="{Binding OverallProgressText}"
                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="2" Spacing="4">
                            <TextBlock Text="Queue" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Text="{Binding IsQueueRunning, Converter={StaticResource StatusToStringConverter}}"
                                       Foreground="{Binding IsQueueRunning, Converter={StaticResource StatusToColorConverter}}"
                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                        </StackPanel>

                        <ProgressBar Grid.Row="1" Grid.ColumnSpan="3"
                                     Value="{Binding OverallProgress}" Maximum="100"
                                     Margin="0,8,0,0" Height="6"
                                     Visibility="{Binding IsQueueRunning, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </Grid>

                    <Grid Grid.Row="3" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Status: " VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding StatusText}"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <ProgressRing Grid.Column="2" Width="20" Height="20"
                                      IsActive="{Binding IsExecuting}"
                                      Visibility="{Binding IsExecuting, Converter={StaticResource BoolToVisibilityConverter}}"
                                      Margin="8,0,0,0" />
                    </Grid>

                    <ctrl:RoboCopyOptionsPanel Grid.Row="4"
                                                Task="{Binding SelectedTask.Model, Mode=OneWay}"
                                                Visibility="{Binding SelectedTask, Converter={StaticResource BoolToVisibilityConverter}}" />
                </Grid>

                <Grid Grid.Row="1" CornerRadius="8"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                      BorderThickness="1" Padding="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Live Log" Style="{StaticResource BodyStrongTextBlockStyle}"
                               Margin="0,0,0,12" />

                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Overall Progress: " VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <ProgressBar Grid.Column="1" Value="{Binding OverallProgress}" Maximum="100"
                                     VerticalAlignment="Center" Height="4" />
                        <TextBlock Grid.Column="2" Text="{Binding OverallProgressText}"
                                   VerticalAlignment="Center" Margin="8,0,0,0"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </Grid>

                    <ListView Grid.Row="2" ItemsSource="{Binding LogEntries}"
                              Padding="0" IsItemClickEnabled="False"
                              SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="m:LogEntry">
                                <StackPanel Orientation="Horizontal" Spacing="8" Padding="2">
                                    <TextBlock Text="{Binding Timestamp, StringFormat='HH:mm:ss'}"
                                               FontSize="11" FontFamily="Consolas"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                               MinWidth="60" />
                                    <TextBlock Text="{Binding Message}"
                                               FontSize="12" FontFamily="Consolas"
                                               Foreground="{Binding Level, Converter={StaticResource LogLevelToColorConverter}}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="4,2" />
                                <Setter Property="MinHeight" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </Grid>
            </Grid>
        </Grid>

        <Grid Grid.Row="2" Height="32" Padding="16,0"
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
              BorderThickness="0,1,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="{Binding StatusText}"
                       VerticalAlignment="Center" FontSize="12"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextTrimming="CharacterEllipsis" />

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4"
                        VerticalAlignment="Center" Margin="16,0">
                <TextBlock Text="Tasks:" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                <TextBlock Text="{Binding Tasks.Count}" FontSize="11"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4"
                        VerticalAlignment="Center">
                <TextBlock Text="Queue:" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                <TextBlock Text="{Binding IsQueueRunning, Converter={StaticResource StatusToStringConverter}}"
                           FontSize="11"
                           Foreground="{Binding IsQueueRunning, Converter={StaticResource StatusToColorConverter}}" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
