<UserControl
    x:Class="RoboCopyGUI.Controls.RoboCopyOptionsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:m="using:RoboCopyGUI.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <m:RoboCopyOptions x:Key="DefaultOptions" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="12">
            <TextBlock Text="RoboCopy Options" Style="{StaticResource BodyStrongTextBlockStyle}"
                       Margin="0,0,0,4" />

            <TextBlock Text="Copy Mode" Style="{StaticResource BodyStrongTextBlockStyle}" FontSize="13" />
            <StackPanel Spacing="6">
                <CheckBox Content="Mirror (/MIR)" x:Name="ChkMirror" />
                <CheckBox Content="Copy Subdirectories (/S)" x:Name="ChkCopySubdirs" IsChecked="True" />
                <CheckBox Content="Copy Empty Subdirectories (/E)" x:Name="ChkCopyEmpty" IsChecked="True" />
                <CheckBox Content="Move Files (/MOVE)" x:Name="ChkMoveFiles" />
                <CheckBox Content="Purge Destination (/PURGE)" x:Name="ChkPurge" />
            </StackPanel>

            <TextBlock Text="Transfer Mode" Style="{StaticResource BodyStrongTextBlockStyle}" FontSize="13" />
            <StackPanel Spacing="6">
                <CheckBox Content="Restartable Mode (/Z)" x:Name="ChkRestart" />
                <CheckBox Content="Backup Mode (/B)" x:Name="ChkBackup" />
                <CheckBox Content="Unbuffered I/O (/J)" x:Name="ChkUnbuffered" />
                <CheckBox Content="EFS Raw Mode (/EFSRAW)" x:Name="ChkEfsRaw" />
            </StackPanel>

            <TextBlock Text="File Attributes" Style="{StaticResource BodyStrongTextBlockStyle}" FontSize="13" />
            <StackPanel Spacing="6">
                <CheckBox Content="Fix File Security (/SEC)" x:Name="ChkFixSec" />
                <CheckBox Content="Fix File Times (/TIMFIX)" x:Name="ChkFixTimes" />
                <CheckBox Content="FAT File Times (/FFT)" x:Name="ChkFatTimes" />
                <CheckBox Content="Disable Dir Timestamps (/DST)" x:Name="ChkDisableDst" />
                <CheckBox Content="Exclude Junctions (/XJ)" x:Name="ChkExcludeJunctions" />
            </StackPanel>

            <TextBlock Text="Logging" Style="{StaticResource BodyStrongTextBlockStyle}" FontSize="13" />
            <StackPanel Spacing="6">
                <CheckBox Content="Verbose Output (/V)" x:Name="ChkVerbose" />
                <CheckBox Content="Include Source Timestamps (/TS)" x:Name="ChkTimestamps" />
                <CheckBox Content="Include File Sizes (/FS)" x:Name="ChkFileSizes" />
                <CheckBox Content="Include File List (/FL)" x:Name="ChkFileList" />
                <CheckBox Content="No Progress (/NP)" x:Name="ChkNoProgress" />
                <CheckBox Content="Show ETA (/ETA)" x:Name="ChkETA" />
                <CheckBox Content="Unicode Log (/UNILOG)" x:Name="ChkUnicodeLog" />
                <CheckBox Content="Full Paths (/FP)" x:Name="ChkFullPaths" />
            </StackPanel>

            <TextBlock Text="Retry Settings" Style="{StaticResource BodyStrongTextBlockStyle}" FontSize="13" />
            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Retry Count (/R):" VerticalAlignment="Center" MinWidth="120" />
                    <NumberBox Value="3" Minimum="0" Maximum="9999" Width="100"
                               x:Name="NumRetryCount" SpinButtonPlacementMode="Inline" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Retry Wait (/W):" VerticalAlignment="Center" MinWidth="120" />
                    <NumberBox Value="5" Minimum="0" Maximum="9999" Width="100"
                               x:Name="NumRetryWait" SpinButtonPlacementMode="Inline" />
                    <TextBlock Text="seconds" VerticalAlignment="Center" Margin="4,0,0,0" />
                </StackPanel>
            </StackPanel>

            <TextBlock Text="Performance" Style="{StaticResource BodyStrongTextBlockStyle}" FontSize="13" />
            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Multi-thread (/MT):" VerticalAlignment="Center" MinWidth="120" />
                    <NumberBox Value="0" Minimum="0" Maximum="128" Width="100"
                               x:Name="NumMultiThread" SpinButtonPlacementMode="Inline"
                               PlaceholderText="0 = auto" />
                </StackPanel>
            </StackPanel>

            <TextBlock Text="Filters" Style="{StaticResource BodyStrongTextBlockStyle}" FontSize="13" />
            <StackPanel Spacing="8">
                <TextBox PlaceholderText="Include patterns (comma-separated, e.g. *.txt,*.doc)"
                         x:Name="TxtIncludePatterns" Header="Include (/IF)" />
                <TextBox PlaceholderText="Exclude file patterns (comma-separated)"
                         x:Name="TxtExcludePatterns" Header="Exclude Files (/XF)" />
                <TextBox PlaceholderText="Exclude directories (comma-separated)"
                         x:Name="TxtExcludeDirs" Header="Exclude Dirs (/XD)" />
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Max Depth (/LEV):" VerticalAlignment="Center" MinWidth="120" />
                    <NumberBox Value="0" Minimum="0" Maximum="999" Width="100"
                               x:Name="NumMaxDepth" SpinButtonPlacementMode="Inline"
                               PlaceholderText="0 = unlimited" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Min Size (/MIN):" VerticalAlignment="Center" MinWidth="120" />
                    <NumberBox Value="0" Minimum="0" Width="120"
                               x:Name="NumMinSize" SpinButtonPlacementMode="Inline"
                               PlaceholderText="bytes" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Max Size (/MAX):" VerticalAlignment="Center" MinWidth="120" />
                    <NumberBox Value="0" Minimum="0" Width="120"
                               x:Name="NumMaxSize" SpinButtonPlacementMode="Inline"
                               PlaceholderText="bytes" />
                </StackPanel>
            </StackPanel>

            <TextBlock Text="Logging File" Style="{StaticResource BodyStrongTextBlockStyle}" FontSize="13" />
            <StackPanel Spacing="8">
                <CheckBox Content="Enable Log File" x:Name="ChkLogFile" />
                <TextBox PlaceholderText="Log file path..." x:Name="TxtLogPath"
                         IsEnabled="{Binding IsChecked, ElementName=ChkLogFile}" />
            </StackPanel>

            <TextBlock Text="Dry Run" Style="{StaticResource BodyStrongTextBlockStyle}" FontSize="13" />
            <CheckBox Content="Preview only (/L) - No files will be copied" x:Name="ChkDryRun" />

            <Button Content="Apply Options" HorizontalAlignment="Stretch"
                    Click="ApplyOptions_Click" Margin="0,8,0,0"
                    Style="{StaticResource AccentButtonStyle}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
