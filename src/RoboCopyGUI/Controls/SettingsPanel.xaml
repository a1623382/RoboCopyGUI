<UserControl
    x:Class="RoboCopyGUI.Controls.SettingsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:m="using:RoboCopyGUI.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" MaxWidth="500">
            <TextBlock Text="应用设置" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,8" />

            <TextBlock Text="常规" Style="{StaticResource BodyStrongTextBlockStyle}" />
            <StackPanel Spacing="12" Padding="0,0,0,12">
                <ToggleSwitch Header="自动保存队列" x:Name="AutoSaveToggle"
                              OnContent="开启" OffContent="关闭" />
                <ToggleSwitch Header="删除前确认" x:Name="ConfirmDeleteToggle"
                              OnContent="开启" OffContent="关闭" />
                <ToggleSwitch Header="启动时自动执行队列" x:Name="AutoStartToggle"
                              OnContent="开启" OffContent="关闭" />
                <ToggleSwitch Header="显示通知" x:Name="NotificationsToggle"
                              OnContent="开启" OffContent="关闭" />
            </StackPanel>

            <TextBlock Text="日志设置" Style="{StaticResource BodyStrongTextBlockStyle}" />
            <StackPanel Spacing="12" Padding="0,0,0,12">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="最大日志条数:" VerticalAlignment="Center" MinWidth="100" />
                    <NumberBox x:Name="MaxLogEntriesBox" Minimum="100" Maximum="100000" Width="120"
                               SpinButtonPlacementMode="Inline" />
                </StackPanel>
                <Button Content="清除日志" Click="TrimLog_Click" HorizontalAlignment="Left" />
            </StackPanel>

            <TextBlock Text="默认路径" Style="{StaticResource BodyStrongTextBlockStyle}" />
            <StackPanel Spacing="12" Padding="0,0,0,12">
                <TextBox Header="默认源路径" x:Name="DefaultSourceBox" PlaceholderText="C:\Source" />
                <TextBox Header="默认目标路径" x:Name="DefaultDestBox" PlaceholderText="D:\Backup" />
            </StackPanel>

            <TextBlock Text="导入 / 导出" Style="{StaticResource BodyStrongTextBlockStyle}" />
            <StackPanel Spacing="8" Padding="0,0,0,12">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="导出队列" Click="ExportQueue_Click" />
                    <Button Content="导入队列" Click="ImportQueue_Click" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="导出 .bat" Click="ExportBat_Click" />
                    <Button Content="导出 .ps1" Click="ExportPs1_Click" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="导出预设" Click="ExportPresets_Click" />
                    <Button Content="导入预设" Click="ImportPresets_Click" />
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                <Button Content="保存设置" Click="SaveSettings_Click" Style="{StaticResource AccentButtonStyle}" />
                <Button Content="恢复默认" Click="ResetSettings_Click" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
