<UserControl
    x:Class="RoboCopyGUI.Controls.SettingsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:m="using:RoboCopyGUI.Models"
    xmlns:vm="using:RoboCopyGUI.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" MaxWidth="500">
            <TextBlock Text="Application Settings" Style="{StaticResource TitleTextBlockStyle}"
                       Margin="0,0,0,8" />

            <Expander Header="General" IsExpanded="True">
                <StackPanel Spacing="12" Padding="0,12">
                    <ToggleSwitch Header="Auto-save Queue"
                                  IsOn="{x:Bind Settings.AutoSaveQueue, Mode=TwoWay}"
                                  OnContent="Enabled" OffContent="Disabled" />
                    <ToggleSwitch Header="Confirm Before Delete"
                                  IsOn="{x:Bind Settings.ConfirmBeforeDelete, Mode=TwoWay}"
                                  OnContent="Enabled" OffContent="Disabled" />
                    <ToggleSwitch Header="Auto-start Queue on Launch"
                                  IsOn="{x:Bind Settings.AutoStartQueueOnLaunch, Mode=TwoWay}"
                                  OnContent="Enabled" OffContent="Disabled" />
                    <ToggleSwitch Header="Show Notifications"
                                  IsOn="{x:Bind Settings.ShowNotifications, Mode=TwoWay}"
                                  OnContent="Enabled" OffContent="Disabled" />
                </StackPanel>
            </Expander>

            <Expander Header="Log Settings">
                <StackPanel Spacing="12" Padding="0,12">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="Max Log Entries:" VerticalAlignment="Center" MinWidth="140" />
                        <NumberBox Value="{x:Bind Settings.MaxLogEntries, Mode=TwoWay}"
                                   Minimum="100" Maximum="100000" Width="120"
                                   SpinButtonPlacementMode="Inline" />
                    </StackPanel>
                    <Button Content="Trim Log Now" Click="TrimLog_Click"
                            Style="{StaticResource SubtleButtonStyle}" HorizontalAlignment="Left">
                        <Button.Icon><FontIcon Glyph="&#xE74D;" /></Button.Icon>
                    </Button>
                </StackPanel>
            </Expander>

            <Expander Header="Default Paths">
                <StackPanel Spacing="12" Padding="0,12">
                    <TextBox Header="Default Source Path"
                             Text="{x:Bind Settings.DefaultSourcePath, Mode=TwoWay}"
                             PlaceholderText="C:\Source" />
                    <TextBox Header="Default Destination Path"
                             Text="{x:Bind Settings.DefaultDestinationPath, Mode=TwoWay}"
                             PlaceholderText="D:\Backup" />
                </StackPanel>
            </Expander>

            <Expander Header="Import / Export">
                <StackPanel Spacing="8" Padding="0,12">
                    <TextBlock Text="Queue" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Export Queue" Click="ExportQueue_Click"
                                Style="{StaticResource SubtleButtonStyle}">
                            <Button.Icon><FontIcon Glyph="&#xE7B3;" /></Button.Icon>
                        </Button>
                        <Button Content="Import Queue" Click="ImportQueue_Click"
                                Style="{StaticResource SubtleButtonStyle}">
                            <Button.Icon><FontIcon Glyph="&#xE8E5;" /></Button.Icon>
                        </Button>
                    </StackPanel>

                    <TextBlock Text="Scripts" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,8,0,0" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Export .bat" Click="ExportBat_Click"
                                Style="{StaticResource SubtleButtonStyle}">
                            <Button.Icon><FontIcon Glyph="&#xE7B3;" /></Button.Icon>
                        </Button>
                        <Button Content="Export .ps1" Click="ExportPs1_Click"
                                Style="{StaticResource SubtleButtonStyle}">
                            <Button.Icon><FontIcon Glyph="&#xE7B3;" /></Button.Icon>
                        </Button>
                    </StackPanel>

                    <TextBlock Text="Presets" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,8,0,0" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Export Presets" Click="ExportPresets_Click"
                                Style="{StaticResource SubtleButtonStyle}">
                            <Button.Icon><FontIcon Glyph="&#xE7B3;" /></Button.Icon>
                        </Button>
                        <Button Content="Import Presets" Click="ImportPresets_Click"
                                Style="{StaticResource SubtleButtonStyle}">
                            <Button.Icon><FontIcon Glyph="&#xE8E5;" /></Button.Icon>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Expander>

            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                <Button Content="Save Settings" Click="SaveSettings_Click"
                        Style="{StaticResource AccentButtonStyle}" />
                <Button Content="Reset to Defaults" Click="ResetSettings_Click"
                        Foreground="OrangeRed" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
